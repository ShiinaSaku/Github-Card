# GitHub Card - Environment Variables

# Required: GitHub personal access token with read access for profile/repo metadata
GITHUB_TOKEN=your_github_token

# Optional: local/dev server port (defaults to 3000)
PORT=3000

# Optional: Bun Redis URL for caching (L2)
REDIS_URL=rediss://default:password@us1-example.upstash.io:6379

# Optional: Vercel KV-compatible aliases
KV_REST_API_URL=
KV_REST_API_TOKEN=
